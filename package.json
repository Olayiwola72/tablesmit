{
  "name": "tablesmit",
  "description": "A minimalist table builder for analytical writing.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate-sitemap && tsc -b && vite build",
    "generate-sitemap": "npx tsx scripts/sitemap/generate-sitemap.ts",
    "lint": "eslint .",
    "audit": "npm audit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "new-post": "npx tsx scripts/md-to-blog-post.ts",
    "prepare": "husky"
  },
  "_comment_overrides": "Pin uuid to fix GHSA-w5hq-g745-h8pq in exceljs dependency chain",
  "overrides": {
    "uuid": "11.1.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.2.8",
