# Tablesmit environment variables
# Copy to .env for local development. Never commit .env.

# Google Analytics 4 (production only)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN (production only)
# VITE_SENTRY_DSN=https://xxxxx@o000000.ingest.sentry.io/0000000

VITE_APP_URL=http://localhost:5173

# Dev.to API key for cross-posting blog posts
# Get from: dev.to → Settings → Account → DEV Community API Key
# VITE_DEVTO_API_KEY=your_api_key_here
