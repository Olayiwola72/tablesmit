# Tablesmit environment variables
# Copy to .env for local development. Never commit .env.

# Google Analytics 4 (production only)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN (production only)
# VITE_SENTRY_DSN=https://xxxxx@o000000.ingest.sentry.io/0000000

VITE_APP_URL=http://localhost:5173

# Dev.to API key for cross-posting blog posts
# Get from: dev.to → Settings → Account → DEV Community API Key
# VITE_DEVTO_API_KEY=your_api_key_here

# Google Search Console API — path to service account JSON key
# Get from: console.cloud.google.com → APIs & Services → Credentials
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Twitter/X API credentials for automated tweet posting
# Get from: developer.twitter.com → Project → Keys and tokens
# TWITTER_API_KEY=your_api_key_here
# TWITTER_API_SECRET=your_api_secret_here
# TWITTER_ACCESS_TOKEN=your_access_token_here
# TWITTER_ACCESS_SECRET=your_access_secret_here
